# .env.example — Polycrise Sentinel: Funding Alert Agent
# ========================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then load in your shell:
#   export $(grep -v '^#' .env | xargs)
#
# Or the agent will auto-load it if python-dotenv is installed.

# ── Gmail SMTP ─────────────────────────────────────────────────────────────────
# Use a Gmail App Password (NOT your regular Gmail password).
# Create one at: Google Account → Security → 2-Step Verification → App Passwords
ALERT_EMAIL_FROM=your_sender@gmail.com
ALERT_EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
ALERT_EMAIL_TO=recipient1@example.com,recipient2@example.com

# ── Schedule ───────────────────────────────────────────────────────────────────
# Time (HH:MM, 24-hour UTC) for the daily scan
ALERT_SCHEDULE_TIME=08:00

# ── Keywords ───────────────────────────────────────────────────────────────────
# Comma-separated; leave unset to use the built-in default list
# ALERT_KEYWORDS=global health,malaria,tuberculosis,maternal health,WASH

# RELIEFWEB_APPNAME: your registered appname (default: ridhismriti-research-8yzpu)
# RELIEFWEB_APPNAME=ridhismriti-research-8yzpu

# Simpler Grants.gov API key — register at https://simpler.grants.gov
# SIMPLER_GRANTS_API_KEY=your-api-key

# UN Partner Portal token — log in at https://www.unpartnerportal.org
# and copy your API token from your profile settings
# UN_PORTAL_TOKEN=your-token

# ── Source toggles (set to "false" to disable a source) ───────────────────────
# ALERTS_GRANTS_GOV=true
# ALERTS_WHO=true
# ALERTS_GATES=true
# ALERTS_WELLCOME=true
# ALERTS_RELIEFWEB=true
# ALERTS_EU_HEALTH=true
# ALERTS_SIMPLER_GRANTS=true
# ALERTS_UN_PORTAL=true

# ── Existing Polycrise Sentinel credentials (unchanged) ───────────────────────
# ACLED_EMAIL=you@email.com
# ACLED_PASSWORD=your-acled-password
# OPENAI_API_KEY=sk-...
